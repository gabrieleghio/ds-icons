{
  "name": "@gabrieleghio/icons-react",
  "version": "0.0.4",
  "description": "React component library for @gabrieleghio/icons",
  "author": "gabrieleghio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrieleghio/ds-icons.git",
    "directory": "packages/react"
  },
  "keywords": [
    "icons",
    "react",
    "components",
    "svg",
    "design-system"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/packages/react/src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/packages/react/src/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  }
}
